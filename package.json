{
  "name": "coconut",
  "module": "src/index.tsx",
  "type": "module",
  "version": "0.1.0",
  "description": "Coconut - A minimal coding agent CLI with TUI interface",
  "bin": {
    "coconut": "./dist/coconut.js"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun run --watch src/index.tsx",
    "build": "bun build src/index.tsx --target=bun --outfile=dist/coconut.js --external react-devtools-core --external yoga-wasm-web"
  },
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.6.2",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  }
}
